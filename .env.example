# Cloudflare Worker Environment Variables
# These are set via `pywrangler secret put <KEY>` for production

# JWT Authentication
JWT_SECRET=<generate-with: python -c "import secrets; print(secrets.token_urlsafe(64))">
JWT_ALGORITHM=HS256

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=r2-thelineone01
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Cloudflare Workers AI (no API key needed - uses binding)
# VTON: pruna/p-image-try-on (native binding)
# LLM: @cf/meta/llama-3.3-70b-instruct (native binding)

# CORS Whitelist (comma-separated domains)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend
REACT_APP_API_URL=https://ft-lineone-api.<your-subdomain>.workers.dev
