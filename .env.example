# Cloudflare Worker Environment Variables
# These are set via `wrangler secret put <KEY>` for production

# JWT Authentication
JWT_SECRET=<your-jwt-secret>
JWT_ALGORITHM=HS256

# Cloudflare R2 Storage
R2_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET=r2-thelineone01
R2_ENDPOINT=https://<account-id>.eu.r2.cloudflarestorage.com

# Cloudflare Workers AI (no API key needed - uses binding)
# VTON: pruna/p-image-try-on (native binding)
# LLM: @cf/meta/llama-3.3-70b-instruct (native binding)

# CORS Whitelist (comma-separated domains)
CORS_ORIGINS=https://thelineone.com,https://www.thelineone.com

# Frontend
REACT_APP_API_URL=https://api.thelineone.com
