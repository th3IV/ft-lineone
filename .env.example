# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ft_lineone

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=ft-lineone-media
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://r2.yourdomain.com

# Replicate (VTON)
REPLICATE_API_TOKEN=your-replicate-api-token
REPLICATE_MODEL=cuuupid/idm-vton

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# API URLs
SCRAPER_API_URL=http://localhost:8001
VTON_API_URL=http://localhost:8002

# Frontend
REACT_APP_API_URL=http://localhost:8000/api/v1
